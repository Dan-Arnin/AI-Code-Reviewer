# --- OCI OBJECT STORAGE (To persist configs & reports) ---
# Set the bucket details where configs and reports will be saved permanently.
OCI_BUCKET_NAME=my_code_reviewer_bucket

# Object Storage Authentication Method (keys or instance_principal)
OCI_STORAGE_AUTH_METHOD=keys
OCI_STORAGE_USER=ocid1.user.oc1...
OCI_STORAGE_TENANCY=ocid1.tenancy.oc1...
OCI_STORAGE_FINGERPRINT=aa:bb:cc...
OCI_STORAGE_REGION=us-ashburn-1
OCI_STORAGE_KEY_CONTENT="-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----"

# --- CORE SETTINGS ---
# Anthropic fallback key if required
ANTHROPIC_API_KEY=sk-ant-api03...

# Path in your bucket for the configuration json (Default: config/runtime_config.json)
# OCI_CONFIG_JSON_OBJECT_NAME=config/runtime_config.json
